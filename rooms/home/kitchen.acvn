#begin start
{{- register_daily "meals_today" 0 -}}
{{ bro_here    = char_at "robert" "home_kitchen" }}
{{ mom_here    = char_at "sandra"  "home_kitchen" }}
{{ dad_here    = char_at "thomas"  "home_kitchen" }}
{{ anyone_here = bro_here || mom_here || dad_here }}
You are standing in the kitchen. It is {{ time_str "HH:mm" }}.
{{ if anyone_here }}
<p>
{{ if bro_here }}{{ robert.properties.firstname }} is here – {{ char_activity "robert" }}.{{ end }}
{{ if mom_here }}{{ sandra.properties.firstname }} is here – {{ char_activity "sandra" }}.{{ end }}
{{ if dad_here }}{{ thomas.properties.firstname }} is here – {{ char_activity "thomas" }}.{{ end }}
</p>
{{ if bro_here }}[[Sit with {{ robert.properties.firstname }}, home_kitchen, join_brother]]{{ end }}
{{ if mom_here }}[[Talk to {{ sandra.properties.firstname }}, home_kitchen, chat_mother]]{{ end }}
{{ if dad_here }}[[Talk to {{ thomas.properties.firstname }}, home_kitchen, chat_father]]{{ end }}
{{ end }}
{{ if vars.meals_today < 3 }}
[[Eat something, home_kitchen, eat]]
{{ else }}
<p>You've already eaten {{ vars.meals_today }} times today. You're full.</p>
{{ end }}
[[Hallway, home_hallway]]
#end

#begin join_brother
{{ bro_activity = char_activity "robert" }}
You sit down across from {{ robert.properties.firstname }} at the kitchen table.
{{ if bro_activity == "having breakfast" || bro_activity == "having a late breakfast" }}
<p>{{ robert.properties.firstname }} is shovelling cornflakes into his mouth in silence while scrolling through his phone. When he notices you, he nods briefly. "Morning."</p>
<p>You have breakfast together for a while without saying much. It's a comfortable silence.</p>
{{ attr_change "mc" "mood" 5 }}
{{ attr_change "mc" "hunger" 15 }}
{{ attr_change "robert" "mood" 3 }}
{{ vars.meals_today = vars.meals_today + 1 }}
{{ else if bro_activity == "having lunch" }}
<p>{{ robert.properties.firstname }} has heated something up and is eating it half-heartedly. "Want some? There's leftover pasta from yesterday."</p>
<p>You eat together and talk a bit about the day.</p>
{{ attr_change "mc" "mood" 7 }}
{{ attr_change "mc" "hunger" 20 }}
{{ attr_change "robert" "mood" 4 }}
{{ vars.meals_today = vars.meals_today + 1 }}
{{ else if bro_activity == "having dinner" }}
<p>{{ robert.properties.firstname }} is sitting at the table with a plate. "Make yourself something too," he says without looking up. You eat in silence, but it doesn't feel uncomfortable.</p>
{{ attr_change "mc" "mood" 6 }}
{{ attr_change "mc" "hunger" 20 }}
{{ attr_change "robert" "mood" 3 }}
{{ vars.meals_today = vars.meals_today + 1 }}
{{ else }}
<p>You chat briefly in the kitchen, then go your separate ways.</p>
{{ attr_change "mc" "mood" 3 }}
{{ end }}
{{ advance_time 15 }}
[[Kitchen, home_kitchen]]
#end

#begin chat_mother
{{ mom_activity = char_activity "sandra" }}
You talk to {{ sandra.properties.firstname }} in the kitchen.
{{ if mom_activity == "preparing breakfast" }}
<p>{{ sandra.properties.firstname }} is standing at the stove, stirring a pot and humming softly. When she hears you, she turns around with a smile. "Good morning, sweetheart. Sit down, I'm almost done."</p>
<p>She puts a plate in front of you. It smells good.</p>
{{ attr_change "mc" "mood" 10 }}
{{ attr_change "mc" "hunger" 20 }}
{{ attr_change "sandra" "mood" 5 }}
{{ vars.meals_today = vars.meals_today + 1 }}
{{ else if mom_activity == "cooking lunch" || mom_activity == "cooking dinner" }}
<p>{{ sandra.properties.firstname }} is busy between pots and pans. "Twenty more minutes," she says without taking her eyes off the stove. "How was your day?"</p>
<p>You chat briefly while she cooks. She listens carefully, even while she keeps stirring.</p>
{{ attr_change "mc" "mood" 8 }}
{{ attr_change "sandra" "mood" 4 }}
{{ else }}
<p>You talk for a moment. {{ sandra.properties.firstname }} asks how you're doing and genuinely listens.</p>
{{ attr_change "mc" "mood" 5 }}
{{ attr_change "sandra" "mood" 3 }}
{{ end }}
{{ advance_time 10 }}
[[Kitchen, home_kitchen]]
#end

#begin chat_father
{{ dad_activity = char_activity "thomas" }}
You talk to {{ thomas.properties.firstname }} in the kitchen.
{{ if dad_activity == "having breakfast" || dad_activity == "having a leisurely breakfast" }}
<p>{{ thomas.properties.firstname }} is sitting at the table with a cup of coffee, reading the news on his phone. He glances up. "Morning. Coffee's still hot."</p>
<p>You have a quick breakfast together. He talks a little about work – more than usual.</p>
{{ attr_change "mc" "mood" 6 }}
{{ attr_change "mc" "hunger" 10 }}
{{ attr_change "thomas" "mood" 4 }}
{{ vars.meals_today = vars.meals_today + 1 }}
{{ else if dad_activity == "having dinner" || dad_activity == "having lunch" }}
<p>{{ thomas.properties.firstname }} has sat down to eat. He makes a welcoming gesture. "Sit down."</p>
<p>You eat together. The conversation is brief but pleasant.</p>
{{ attr_change "mc" "mood" 5 }}
{{ attr_change "mc" "hunger" 15 }}
{{ attr_change "thomas" "mood" 3 }}
{{ vars.meals_today = vars.meals_today + 1 }}
{{ else }}
<p>You exchange a few words. {{ thomas.properties.firstname }} is friendly, if a little short.</p>
{{ attr_change "mc" "mood" 3 }}
{{ end }}
{{ advance_time 10 }}
[[Kitchen, home_kitchen]]
#end

#begin eat
You quickly cook something and eat.
{{ vars.meals_today = vars.meals_today + 1 }}
{{ attr_change "mc" "hunger" 30 }}
{{ attr_change "mc" "energy" 10 }}
{{ advance_time 20 }}
<p>That hit the spot! It's now {{ time_str "HH:mm" }}.</p>
[[Kitchen, home_kitchen]]
#end
